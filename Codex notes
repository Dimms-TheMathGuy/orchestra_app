The service logic should be:

async createProject(userId: string, body: { name: string; description?: string }) {
  return this.prisma.$transaction(async (tx) => {
    const project = await tx.project.create({
      data: {
        name: body.name.trim(),
        description: body.description?.trim() || null,
        ownerId: userId,
      },
    });

    await tx.projectMember.create({
      data: {
        userId,
        projectId: project.id,
        role: 'OWNER',
      },
    });

    return {
      ...project,
      integrations: {
        notion: false,
        github: false,
        zoom: false,
      },
    };
  });
}
