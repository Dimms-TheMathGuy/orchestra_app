// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  password   String
  name       String
  company    String?
  avatarUrl  String?
  googleId   String?
  createdAt  DateTime @default(now())

  projectsOwned    Project[]       @relation("ProjectOwner")
  memberships      ProjectMember[]
  messages         ProjectMessage[]
  githubId         Int? @unique
  githubUsername   String?
  githubToken      String?
}

model Project {
  id            String   @id @default(uuid())
  name          String
  description   String?
  ownerId       String
  createdAt     DateTime @default(now())
  notionDbId    String?
  notionSchema  Json?
  zoomMeetingId String?

  owner        User               @relation("ProjectOwner", fields: [ownerId], references: [id])
  members      ProjectMember[]
  messages     ProjectMessage[]
  meetings     MeetingLog[]
  repositories ProjectRepository[]
  branches     GithubBranchLink[]
  activities   GithubActivity[]
}

model ProjectMember {
  id        String   @id @default(uuid())
  userId    String
  projectId String
  role      String
  joinedAt  DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  project Project @relation(fields: [projectId], references: [id])

  @@unique([userId, projectId])
}

model ProjectMessage {
  id        String   @id @default(uuid())
  projectId String
  senderId  String
  content   String
  iv        String
  isSystem  Boolean  @default(false)
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id])
  sender  User    @relation(fields: [senderId], references: [id])
}

model MeetingLog {
  id            String   @id @default(uuid())
  projectId     String
  zoomMeetingId String
  topic         String?
  recordingUrl  String?
  transcriptVtt String?
  aiSummary     String?
  actionItems   Json?
  status        String?
  createdAt     DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id])
  transcripts Transcript[] 
}

model ProjectRepository {
  id            String   @id @default(uuid())
  projectId     String
  githubOwner   String
  githubRepo    String
  githubUrl     String
  webhookSecret String?
  createdAt     DateTime @default(now())

  project   Project            @relation(fields: [projectId], references: [id])
  branches  GithubBranchLink[]
  activities GithubActivity[]   
}

model GithubBranchLink {
  id           String   @id @default(uuid())
  projectId    String
  repoId       String 
  branchName   String
  notionTaskId String?
  prNumber     Int? 
  prUrl        String?
  status       String?
  updatedAt    DateTime @updatedAt

  project Project            @relation(fields: [projectId], references: [id])
  repo    ProjectRepository  @relation(fields: [repoId], references: [id])
}

model GithubActivity {
  id          String   @id @default(uuid())
  projectId   String
  repoId      String
  type        String      // commit/pr/issue/ merge
  githubId    String?     // commit SHA /PR ID/issue ID
  title       String
  description String?
  author      String
  url         String
  createdAt   DateTime

  project Project            @relation(fields: [projectId], references: [id])
  repo    ProjectRepository  @relation(fields: [repoId], references: [id])

  @@unique([repoId, githubId, type])
}

model Transcript {
  id        String   @id @default(uuid())
  meetingId String
  text      String
  createdAt DateTime @default(now())

  meeting   MeetingLog @relation(fields: [meetingId], references: [id])
}